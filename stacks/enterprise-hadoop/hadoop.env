# Enterprise Hadoop 3.4.1 — env vars consumed by the custom entrypoint to generate
# core-site.xml, hdfs-site.xml, yarn-site.xml and mapred-site.xml.
#
# Docker-friendly subset (HTTP_ONLY, no Ranger, no keystore). The live techsophy.com
# cluster runs HTTPS_ONLY with a real keystore — to enable that, layer a keystore
# into the image and re-add the hadoop_ssl_* / dfs_http_policy=HTTPS_ONLY block.
#
# Naming convention (bde2020):  _ → .   (dot)   |   ___ → -   (hyphen)

# ── Core ─────────────────────────────────────────────────────────────────────
CORE_CONF_fs_defaultFS=hdfs://namenode:9820
CORE_CONF_hadoop_tmp_dir=/var/tmp/hadoop
CORE_CONF_hadoop_http_staticuser_user=hadoop
CORE_CONF_hadoop_proxyuser_airflow_groups=hadoop
CORE_CONF_hadoop_proxyuser_airflow_hosts=*
CORE_CONF_hadoop_security_group_mapping=org.apache.hadoop.security.ShellBasedUnixGroupsMapping

# ── HDFS ─────────────────────────────────────────────────────────────────────
HDFS_CONF_dfs_datanode_data_dir=file:///hadoop/dfs/data
HDFS_CONF_dfs_namenode_name_dir=file:///hadoop/dfs/name
# edits.dir defaults to name.dir when unset; we don't mount a separate /hadoop/dfs/edits volume.
HDFS_CONF_dfs_replication=1
HDFS_CONF_dfs_namenode_rpc___address=namenode:9820
HDFS_CONF_dfs_namenode_http___address=namenode:9870
HDFS_CONF_dfs_permissions_enabled=true
HDFS_CONF_dfs_permissions_superusergroup=supergroup
HDFS_CONF_fs_permissions_umask___mode=027
HDFS_CONF_dfs_client_block_write_replace___datanode___on___failure_policy=NEVER

# HTTP-only (HTTPS path requires a keystore which this docker image doesn't bundle)
HDFS_CONF_dfs_http_policy=HTTP_ONLY
HDFS_CONF_dfs_webhdfs_enabled=true

# Bind on all interfaces inside the container so docker can route traffic in
HDFS_CONF_dfs_namenode_rpc___bind___host=0.0.0.0
HDFS_CONF_dfs_namenode_servicerpc___bind___host=0.0.0.0
HDFS_CONF_dfs_namenode_http___bind___host=0.0.0.0
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false
HDFS_CONF_dfs_client_use_datanode_hostname=true
HDFS_CONF_dfs_datanode_use_datanode_hostname=true

# ── YARN ─────────────────────────────────────────────────────────────────────
YARN_CONF_yarn_resourcemanager_hostname=resourcemanager
YARN_CONF_yarn_resourcemanager_address=resourcemanager:8032
YARN_CONF_yarn_resourcemanager_scheduler_address=resourcemanager:8030
YARN_CONF_yarn_resourcemanager_resource___tracker_address=resourcemanager:8031
YARN_CONF_yarn_resourcemanager_webapp_address=resourcemanager:8088
YARN_CONF_yarn_resourcemanager_bind___host=0.0.0.0
YARN_CONF_yarn_resourcemanager_recovery_enabled=true
YARN_CONF_yarn_resourcemanager_store_class=org.apache.hadoop.yarn.server.resourcemanager.recovery.FileSystemRMStateStore
YARN_CONF_yarn_resourcemanager_scheduler_class=org.apache.hadoop.yarn.server.resourcemanager.scheduler.capacity.CapacityScheduler
YARN_CONF_yarn_log___aggregation___enable=true
YARN_CONF_yarn_http_policy=HTTP_ONLY
YARN_CONF_yarn_nodemanager_aux___services=mapreduce_shuffle
YARN_CONF_yarn_nodemanager_remote___app___log___dir=/app-logs
YARN_CONF_yarn_nodemanager_resource_memory___mb=4096
YARN_CONF_yarn_nodemanager_resource_cpu___vcores=4
YARN_CONF_yarn_nodemanager_bind___host=0.0.0.0
YARN_CONF_yarn_nodemanager_webapp_address=nodemanager:8042
YARN_CONF_yarn_timeline___service_enabled=true
YARN_CONF_yarn_timeline___service_generic___application___history_enabled=true
YARN_CONF_yarn_timeline___service_hostname=historyserver
YARN_CONF_yarn_timeline___service_bind___host=0.0.0.0

# ── MapReduce ────────────────────────────────────────────────────────────────
MAPRED_CONF_mapreduce_framework_name=yarn
MAPRED_CONF_mapreduce_jobhistory_address=historyserver:10020
MAPRED_CONF_mapreduce_jobhistory_webapp_address=historyserver:19888
MAPRED_CONF_mapreduce_jobhistory_http_policy=HTTP_ONLY
MAPRED_CONF_mapreduce_jobhistory_bind___host=0.0.0.0
