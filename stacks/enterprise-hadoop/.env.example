# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Enterprise On-Prem Datalake — template (commit this file, NOT .env)     ║
# ║  Copy to .env and fill in real values.                                   ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# PostgreSQL
POSTGRES_ROOT_PASSWORD=changeme

# Hive Metastore DB (live username 'hive')
HMS_DB_NAME=metastore
HMS_DB_USER=hive
HMS_DB_PASSWORD=changeme

# Ranger
RANGER_DB_NAME=ranger
RANGER_DB_USER=ranger
RANGER_DB_PASSWORD=changeme
RANGER_ADMIN_PASSWORD=changeme
RANGER_USERSYNC_PASSWORD=changeme

# HDFS / Hadoop TLS keystore (live uses one shared keystore for HDFS+YARN+MR)
HDFS_KEYSTORE_PASSWORD=changeme
HDFS_KEYSTORE_KEY_PASSWORD=changeme
HDFS_TRUSTSTORE_PASSWORD=changeme

# Spark SSL + internal auth shared secret
SPARK_SSL_PASSWORD=changeme
SPARK_AUTH_SECRET=changeme

# Airflow
# Generate fernet:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_WEBSERVER_SECRET_KEY=changeme
AIRFLOW_ADMIN_PASSWORD=changeme

# RabbitMQ (Celery broker)
RABBITMQ_USER=airflow
RABBITMQ_PASSWORD=changeme

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# YARN NodeManager sizing (live: 17 vcores / 34816 MB). Lower if host is smaller.
YARN_NM_VCORES=4
YARN_NM_MEMORY_MB=8192
