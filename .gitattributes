# Treat these as binary so git never applies EOL (CRLF/LF) normalization,
# which would corrupt them. Covers the generated docs, images, and archives.
*.pdf   binary
*.docx  binary
*.doc   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.xlsx  binary
*.tar.gz binary
*.gz    binary
*.zip   binary
